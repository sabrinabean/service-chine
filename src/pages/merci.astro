---
import BaseLayout from "../layouts/BaseLayout.astro";
const title = "Demande envoyée - SERVICE CHINE";
const description = "Votre demande a bien été envoyée.";
---
<BaseLayout title={title} description={description}>
  <div slot="content">
    <h1 style="font-size:24pt; text-align:center; color:#DC0000; font-weight:600; margin-bottom:0.75em;">
      Merci !
    </h1>
    <p style="text-align:center; font-size:15px; line-height:1.8; margin-bottom:1.5em;">
      Votre demande a bien été envoyée. Nous reviendrons vers vous dans les plus brefs délais.
    </p>
    <p style="text-align:center; margin-top:2.5em;">
      <a href="/" style="color:#DC214C; text-decoration:none;">← Retour à l'accueil</a>
    </p>
  </div>
</BaseLayout>
