---
import Layout from "../layouts/Main.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="Demande envoyée" description="Votre demande a bien été envoyée.">
  <section class="section">
    <div class="container max-w-2xl text-center">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-main text-white">
        <Icon name="lucide:check" size={32} />
      </div>
      <h1 class="font-semibold text-2xl lg:text-4xl mb-4">Merci !</h1>
      <p class="text-lg mb-8">
        Votre demande a bien été envoyée. Nous reviendrons vers vous dans les
        plus brefs délais.
      </p>
      <a href="/" class="btn bg-main border-main text-white rounded-lg hover:bg-main-dark">
        <Icon name="lucide:arrow-left" size={18} /> Retour à l'accueil
      </a>
    </div>
  </section>
</Layout>
