---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Main.astro";
import Pagination from "../../components/pagination.astro";
import NewsCard from "../../components/card/NewsCardMain.astro";

export async function getStaticPaths({ paginate }) {
  const posts = (await getCollection("blog")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  return paginate(posts, {
    pageSize: 6,
  });
}

const { page } = Astro.props;

const site = Astro.site?.toString() ?? "";

const baseUrl = `${site}blog/`;

const itemList = page.data.map((post, index) => {
  return {
    "@type": "ListItem",
    "position": index + 1 + (page.currentPage - 1) * page.size,
    "url": `${site}blog/${post.id}/`,
  };
});
---

<!-- ✅ SEO: CollectionPage + ItemList -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Blog",
  "url": "${baseUrl}",
  "mainEntity": {
    "@type": "ItemList",
    "itemListElement": ${JSON.stringify(itemList)}
  }
}
</script>

<Layout title="Blog">
  <section class="section">
    <div class="container">

      <!-- Breadcrumbs -->
      <div class="breadcrumbs text-sm mb-6">
        <ul class="flex! flex-wrap">
          <li><a href="/">Accueil</a></li>
          <li>Blog</li>
        </ul>
      </div>

      <!-- Posts grid -->
      <ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 items-stretch">
        {
          page.data.map((post) => (
            <li>
              <NewsCard {...post} />
            </li>
          ))
        }
      </ul>

      {page.lastPage != 1 && <Pagination page={page} />}

    </div>
  </section>
</Layout>