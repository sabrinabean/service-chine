---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  error: unknown;
}
const { error } = Astro.props;
---
<BaseLayout title="Erreur serveur - SERVICE CHINE">
  <div slot="content" style="text-align:center; padding:40px 0;">
    <h1 style="font-size:24pt; color:#DC0000; font-weight:600; margin-bottom:0.5em;">500 — Erreur serveur</h1>
    <p style="font-size:15px; line-height:1.8; margin:1em 0 2em;">
      Une erreur est survenue. Veuillez réessayer ultérieurement.
    </p>
    <p style="text-align:center; margin-top:1em;">
      <a href="/" style="color:#DC214C; text-decoration:none;">← Retour à l'accueil</a>
    </p>
  </div>
</BaseLayout>
