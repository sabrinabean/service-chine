---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ContactForm.astro';
const title = "Contact - SERVICE CHINE";
const description = "Contactez SERVICE CHINE pour vos projets d'import-export, fabrication, achat ou vente en Chine.";
---

<BaseLayout title={title} description={description}>
  <div slot="content">
    <!-- 标题：24pt，颜色 #DC0000，居中，加粗 -->
    <h1 style="font-size:24pt; text-align:center; margin-bottom:0.75em; font-weight:600; color:#DC0000;">
      Contactez-nous
    </h1>
    <!-- 描述文字：左对齐 -->
    <p style="margin-bottom:30px; text-align:left;">N'hésitez pas à nous contacter pour toute question ou projet. Nous vous répondrons dans les plus brefs délais.</p>

    <!-- 表单块：完全参照 index.astro 的结构 -->
    <div style="margin-top:30px; background:#f5f5f5; padding:20px; border-radius:6px; text-align:center;">
      <!-- 图片 + 联系信息部分 -->
      <div style="margin-bottom:20px;">
        <!-- Google 动态地图：标记 Guangzhou 和 Hong Kong（使用你的自定义地图） -->
        <div style="margin-bottom:20px; position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:6px;">
          <iframe 
            src="https://www.google.com/maps/d/u/0/embed?mid=18svlH__X1yjqJyLv76zk8F6DM7SbqYY&ehbc=2E312F" 
            style="position:absolute; top:0; left:0; width:100%; height:100%; border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            title="Google My Maps - Guangzhou et Hong Kong">
          </iframe>
        </div>

        <img src="/assets/Demande_devis.png" alt="SERVICE CHINE CONTACT US" style="width:35%; max-width:100%; display:block; margin:0 auto; height:auto;">
        
        <div class="elementor-social-icons-wrapper" style="justify-content:center; margin-top:10px;">
          <a class="elementor-icon" href="#"><i class="fab fa-facebook-f"></i></a>
          <a class="elementor-icon" href="#"><i class="fab fa-twitter"></i></a>
          <a class="elementor-icon" href="#"><i class="fab fa-instagram"></i></a>
          <a class="elementor-icon" href="#"><i class="fab fa-linkedin-in"></i></a>
          <a class="elementor-icon" href="#"><i class="fab fa-youtube"></i></a>
          <a class="elementor-icon" href="#"><i class="fab fa-weixin"></i></a>
        </div>
      </div>

      <!-- 表单：宽度70%，居中，输入框100% -->
      <ContactForm />
    </div>
  </div>
</BaseLayout>

<!-- 全局超链接样式（与 index.astro 完全一致） -->
<style>
  a {
    color: #DC214C !important;
    text-decoration: none !important;
    border-bottom: none !important;
  }
  a:hover {
    color: #b01a3a !important;
  }
</style>
