---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Main.astro";
import Pagination from "../../components/pagination.astro";
import ServiceCard from "../../components/card/ServiceCard.astro";

export async function getStaticPaths({ paginate }) {
  const service = (await getCollection("service")).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return paginate(service, {
    pageSize: 6,
  });
}

const { page } = Astro.props;
---

<Layout title="Service">
  <section class="section">
    <div class="container">
      <div class="breadcrumbs text-sm mb-6">
        <ul class="flex! flex-wrap">
          <li><a href="/">Accueil</a></li>
          <li>Services</li>
        </ul>
      </div>

      <ul
        class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-10 items-stretch"
      >
        {
          page.data.map((post) => (
            <li>
              <ServiceCard {...post} />
            </li>
          ))
        }
      </ul>

      {page.lastPage != 1 && <Pagination page={page} />}
    </div>
  </section>
</Layout>
