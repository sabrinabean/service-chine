---
import { Icon } from "astro-icon/components";
---

<section class="section section-contacts">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
      <div>
        <h3 class="font-semibold text-xl lg:text-[40px]">Nous trouver</h3>
        <div class="mt-10 grid gap-6">
          <div
            class="grid grid-cols-[54px_1fr] gap-4 items-center dark:bg-dark dark:border-dark bg-gray-50 border border-gray-200 rounded-lg p-4"
          >
            <div
              class="bg-main text-white flex items-center justify-center rounded-full w-13.5 h-13.5"
            >
              <Icon name="lucide:phone-call" size={24} />
            </div>
            <div>
              <p class="font-semibold text-lg mb-0">Appelez-nous</p>
              <a href="tel:+(08)255201888">+(08) 255 201 888</a>
            </div>
          </div>

          <div
            class="grid grid-cols-[54px_1fr] gap-4 items-center dark:bg-dark dark:border-dark bg-gray-50 border border-gray-200 rounded-lg p-4"
          >
            <div
              class="bg-main text-white flex items-center justify-center rounded-full w-13.5 h-13.5"
            >
              <Icon name="lucide:mail" size={24} />
            </div>
            <div>
              <p class="font-semibold text-lg mb-0">Envoyer un e-mail</p>
              <a href="mailto:Hello@procleaning.com">Hello@procleaning.com</a>
            </div>
          </div>

          <div
            class="grid grid-cols-[54px_1fr] gap-4 items-center dark:bg-dark dark:border-dark bg-gray-50 border border-gray-200 rounded-lg p-4"
          >
            <div
              class="bg-main text-white flex items-center justify-center rounded-full w-13.5 h-13.5"
            >
              <Icon name="lucide:map-pin" size={24} />
            </div>
            <div>
              <p class="font-semibold text-lg mb-0">Adresse</p>
              <a href="#"
                ><address class="not-italic">
                  7510, Brand Tower, New York, USA
                </address></a
              >
            </div>
          </div>
        </div>
      </div>
      <div>
        <p class="text-sm mb-0">Coordonnées</p>
        <h3 class="font-semibold text-xl lg:text-[40px] mb-3">Restons en contact</h3>
        <p class="">
          Nous nous efforçons de répondre à vos demandes dans les meilleurs
          délais afin que vous receviez l'aide dont vous avez besoin.
        </p>

        <form action="/api/lead" method="POST" class="mt-8 grid gap-3">
          <fieldset class="fieldset">
            <input
              type="text"
              placeholder="Nom *"
              class="input w-full validator"
              id="contact-name"
              name="name"
              required
              maxlength="100"
            />
            <p class="validator-hint hidden">Champ obligatoire</p>
          </fieldset>

          <fieldset class="fieldset">
            <input
              type="email"
              placeholder="E-mail *"
              class="input w-full validator"
              id="contact-email"
              name="email"
              required
              maxlength="120"
            />
            <p class="validator-hint hidden">Champ obligatoire</p>
          </fieldset>

          <fieldset class="fieldset">
            <input
              type="text"
              placeholder="Société"
              class="input w-full"
              id="contact-company"
              name="company"
              maxlength="120"
            />
          </fieldset>

          <fieldset class="fieldset">
            <textarea
              class="textarea w-full validator"
              placeholder="Votre message *"
              id="contact-msg"
              name="message"
              required
              minlength="10"
              maxlength="3000"></textarea>
            <p class="validator-hint hidden">Champ obligatoire</p>
          </fieldset>

          <!-- 蜜罐字段:对用户隐藏,机器人会填;Function 见到此字段非空即拒 -->
          <input
            type="text"
            name="company_website"
            tabindex="-1"
            autocomplete="off"
            class="hidden"
            aria-hidden="true"
          />

          <!-- Cloudflare Turnstile:防机器人(占位,site key 上线时填入) -->
          <div class="cf-turnstile" data-sitekey="<PUBLIC_TURNSTILE_SITE_KEY>"></div>
          <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

          <button
            class="btn bg-main border-main text-white rounded-lg hover:bg-green-600 shadow-none lg:mr-auto"
            type="submit">Envoyer ma demande</button
          >
        </form>
      </div>
    </div>
  </div>
</section>
