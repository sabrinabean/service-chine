---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Swiper from "../Swiper.astro";
---

<section class="section section-reviews">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-10 items-center">
      <div>
        <h2>Feedback About Their Experience With Us</h2>
        <p class="mt-4">
          Read testimonials from our satisfied clients. See how our cleaning
          services have made a difference in their lives and homes
        </p>
      </div>
      <div>
        <Swiper
          pagination={false}
          navigation={true}
          id="mySwiper"
          prev="swiper-prev"
          next="swiper-next"
        >
          <div class="swiper-slide">
            <article
              class="rounded-xl p-10 grid grid-cols-1 sm:grid-cols-[100px_1fr] gap-4 items-center border border-gray-200 border-t-4 border-t-main border-r-4 border-r-main relative"
            >
              <Image
                src="/img/comments/cmnt1.webp"
                alt=""
                format="webp"
                quality={45}
                width="100"
                height="100"
                class="w-full h-auto max-w-25"
              />
              <div class="grid gap-0">
                <div class="flex flex-wrap justify-between items-center gap-4">
                  <div>
                    <p class="text-lg font-semibold">Robert Fox</p>
                    <p>Business Man</p>
                  </div>
                  <Image
                    src="/img/icons/quote.svg"
                    width="50"
                    height="50"
                    alt="quote"
                    class="w-auto h-auto max-w-18.75 absolute top-2 right-2"
                  />
                </div>

                <div class="flex gap-1 items-center text-yellow-500 mt-2 mb-4">
                  {
                    Array.from({ length: 5 }).map((star) => (
                      <Icon name="heroicons:star-solid" size={24} />
                    ))
                  }
                </div>

                <p class="text-sm">
                  Excellent service! The team was punctual, thorough, and left
                  my home sparkling clean. Highly recommend for anyone needing a
                  reliable and detailed cleaning service
                </p>
              </div>
            </article>
          </div>
          <div class="swiper-slide">
            <article
              class="rounded-xl p-10 grid grid-cols-1 sm:grid-cols-[100px_1fr] gap-4 items-center border border-gray-200 border-t-4 border-t-main border-r-4 border-r-main relative"
            >
              <Image
                src="/img/comments/cmnt1.webp"
                alt=""
                format="webp"
                quality={45}
                width="100"
                height="100"
                class="w-full h-auto max-w-25"
              />
              <div class="grid gap-0">
                <div class="flex flex-wrap justify-between items-center gap-4">
                  <div>
                    <p class="text-lg font-semibold">Robert Fox</p>
                    <p>Business Man</p>
                  </div>
                  <Image
                    src="/img/icons/quote.svg"
                    width="50"
                    height="50"
                    alt="quote"
                    class="w-auto h-auto max-w-18.75 absolute top-2 right-2"
                  />
                </div>

                <div class="flex gap-1 items-center text-yellow-500 mb-4">
                  {
                    Array.from({ length: 5 }).map((star) => (
                      <Icon name="heroicons:star-solid" size={24} />
                    ))
                  }
                </div>

                <p class="text-sm">
                  Excellent service! The team was punctual, thorough, and left
                  my home sparkling clean. Highly recommend for anyone needing a
                  reliable and detailed cleaning service
                </p>
              </div>
            </article>
          </div>
          <div class="swiper-slide">
            <article
              class="rounded-xl p-10 grid grid-cols-1 sm:grid-cols-[100px_1fr] gap-4 items-center border border-gray-200 border-t-4 border-t-main border-r-4 border-r-main relative"
            >
              <Image
                src="/img/comments/cmnt1.webp"
                alt=""
                format="webp"
                quality={45}
                width="100"
