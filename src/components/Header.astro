---
import Navabar from "../components/Navbar.astro";
import Logo from "../components/Logo.astro";
import { Icon } from "astro-icon/components";

const isHome = Astro.url.pathname === "/";
---

<header class="header">
  <div class="navbar w-full">
    <div
      class="container grid grid-cols-[204px_1fr] lg:grid-cols-[204px_1fr_auto] items-center"
    >
      <Logo />

      <Navabar />
      <div class="flex gap-3 ml-auto">
        <a
          href="#"
          class="hidden sm:flex btn bg-main border-main text-white rounded-lg hover:bg-green-600"
          >Demander un devis</a
        >
        <div class="flex-none lg:hidden">
          <label
            for="my-drawer-2"
            aria-label="open sidebar"
            class="btn btn-square btn-ghost ml-2"
          >
            <Icon name="lucide:menu" />
          </label>
        </div>
      </div>
    </div>
  </div>
</header>
