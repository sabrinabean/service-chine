---
import { Icon } from "astro-icon/components";
import { formatFrontmatterDate } from "../../utils/date";
import { resolveCategory } from "../../utils/categories";
import { Image } from "astro:assets";

const { id, data } = Astro.props;
const category = await resolveCategory(data.category);
---

<article class="group">
  <a href={`/blog/${id}`} class="flex flex-col gap-3 h-full">
    {
      data.thumbnail && (
        <Image
          src={data.thumbnail}
          alt={data.title}
          width="500"
          height="250"
          format="webp"
          quality={45}
          class="rounded-xl aspect-2/1 w-full h-auto object-cover mb-4"
        />
      )
    }

    <div
      class="text-center w-full flex-1 flex flex-col justify-between items-center"
    >
      <p
        class="flex flex-wrap gap-2 gap-x-4 items-center uppercase justify-center"
      >
        <span class="btn btn-outline px-3 py-1 h-auto text-xs rounded-md"
          >{category.title}</span
        >
        <span>{data.author.name}</span>
        <time datetime={data.pubDate.toISOString()}>
          {formatFrontmatterDate(data.pubDate)}
        </time>
      </p>
      <h3 class="font-semibold text-xl sm:text-2xl my-4 group-hover:underline">
        {data.title}
      </h3>
      <p class="mb-6 text-sm sm:text-base">{data.description}</p>

      <button
        class="btn btn-outline hover:bg-main hover:text-white hover:border-main rounded-lg mt-auto"
      >
        Lire la suite
        <Icon name="lucide:arrow-up-right" size={16} />
      </button>
    </div>
  </a>
</article>
