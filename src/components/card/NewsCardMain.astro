---
import { Icon } from "astro-icon/components";
import { formatFrontmatterDate } from "../../utils/date";
import { resolveCategory } from "../../utils/categories";
import { Image } from "astro:assets";

const { id, data } = Astro.props;
const category = await resolveCategory(data.category);
---

<article
  class="group h-full flex flex-col gap-3 border border-gray-200 overflow-hidden rounded-xl"
>
  {
    data.thumbnail && (
      <div class="grid">
        <a href={`/blog/${id}`} class="[grid-area:1/1/2/2]">
          <Image
            src={data.thumbnail}
            alt={data.title}
            width="500"
            height="250"
            format="webp"
            quality={45}
            class="aspect-2/1 w-full h-auto object-cover "
          />
        </a>
        <a
          href={`/blog/${category.slug}`}
          class="btn bg-main border-main shadow-none text-white px-3 py-1 h-auto text-xs rounded-md [grid-area:1/1/2/2] mb-auto mr-auto mt-2 ml-2"
        >
          {category.title}
        </a>
      </div>
    )
  }

  <div
    class="text-center w-full flex-1 flex flex-col justify-between items-center p-4"
  >
    <p
      class="flex flex-wrap gap-2 gap-x-4 items-center uppercase justify-center text-sm mb-4"
    >
      <a href={`/auhors/${data.author.id}`} class="hover:underline"
        >{data.author.name}</a
      >
      <time datetime={data.pubDate.toISOString()}>
        {formatFrontmatterDate(data.pubDate)}
      </time>
    </p>
    <a href={`/blog/${id}`} class="flex-1 flex flex-col justify-between w-full">
      <h3 class="font-semibold text-xl sm:text-2xl group-hover:underline">
        {data.title}
      </h3>
      <p class="mb-6 text-sm sm:text-base">{data.description}</p>

      <button
        class="btn bg-main border-main text-white rounded-lg hover:bg-green-600 w-full mt-auto"
      >
        Read more
        <Icon name="lucide:arrow-up-right" size={16} />
      </button>
    </a>
  </div>
</article>
